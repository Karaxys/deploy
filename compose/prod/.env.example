# ─────────────────────────────────────────────────────────────────────────────
# Karaxys self-host / production environment — TEMPLATE.
#
# DO NOT fill this in by hand. Run:   make init   (or ./scripts/generate-secrets.sh)
# It writes compose/prod/.env with unique, cryptographically random secrets.
#
# This template documents every variable. Every value marked <GENERATED> must be
# a strong random secret — the stack refuses to start if any is missing.
# ─────────────────────────────────────────────────────────────────────────────

COMPOSE_PROJECT_NAME=karaxys

# Deployment mode.
#   development = local / LAN evaluation on localhost (secrets are STILL enforced)
#   production  = extra-strict validation; requires real non-localhost URLs + TLS
KARAXYS_ENV=development

# Published images. Flip the GHCR packages to Public, or `docker login ghcr.io`.
KARAXYS_IMAGE_REGISTRY=ghcr.io/karaxys
KARAXYS_IMAGE_TAG=latest

# Public URLs — EDIT for anything other than a single-box localhost run.
KARAXYS_PUBLIC_API_BASE_URL=http://localhost:8081
KARAXYS_API_BASE_URL=http://localhost:8081
KARAXYS_ALLOWED_ORIGINS=http://localhost:7000

# Secrets — generate with the commands shown; never commit real values.
KARAXYS_SECRET_KEY_B64=<GENERATED: openssl rand -base64 32>
KARAXYS_API_KEY=<GENERATED: openssl rand -hex 24>
KARAXYS_AGENT_TOKEN=<GENERATED: openssl rand -hex 24>

MONGO_ROOT_USERNAME=karaxys
MONGO_ROOT_PASSWORD=<GENERATED: openssl rand -hex 24>
MONGO_DB_NAME=karaxys

MINIO_ROOT_USER=karaxys
MINIO_ROOT_PASSWORD=<GENERATED: openssl rand -hex 24>
KARAXYS_OBJECTSTORE_BUCKET=karaxys

KARAXYS_REDIS_PASSWORD=<GENERATED: openssl rand -hex 24>

# First-run admin account (created once by the admin-seed service).
KARAXYS_ADMIN_EMAIL=admin@karaxys.local
KARAXYS_ADMIN_PASSWORD=<GENERATED: strong password>
KARAXYS_ADMIN_NAME=Karaxys Admin

# Monitoring profile (optional): docker compose --profile monitoring up
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<GENERATED: openssl rand -hex 16>
