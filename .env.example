# Karaxys dev deployment settings.
#
# Copy to .env and adjust hostnames before starting Compose:
#   cp .env.example .env
#   docker compose --env-file .env -f compose/dev/docker-compose.yml up -d --build

COMPOSE_PROJECT_NAME=karaxys

# Build contexts are relative to deploy/compose/dev/docker-compose.yml.
KARAXYS_BACKEND_CONTEXT=../../../karaxys_backend
KARAXYS_DASHBOARD_CONTEXT=../../../dashboard
KARAXYS_EBPF_CONTEXT=../../../ebpf_tracer

KARAXYS_PUBLIC_API_BASE_URL=http://localhost:8081
KARAXYS_ALLOWED_ORIGINS=http://localhost:7000

MONGO_DB_NAME=karaxys
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=

KARAXYS_API_KEY=dev-api-key-with-at-least-24-chars
KARAXYS_AGENT_TOKEN=docker-agent-token-with-at-least-24-chars
KARAXYS_SECRET_KEY_B64=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=

MINIO_ROOT_USER=karaxys
MINIO_ROOT_PASSWORD=karaxys-local-minio-password
KARAXYS_OBJECTSTORE_BUCKET=karaxys-local

TRAFFIC_LOG_MAX_EVENTS=1000
TRAFFIC_LOG_TTL_HOURS=24
MONGO_INDEX_TIMEOUT_SECONDS=300

KARAXYS_SCANNER_GLOBAL_CONCURRENCY=2
KARAXYS_SCANNER_TARGET_JOBS_PER_WINDOW=1
KARAXYS_SCANNER_TARGET_RATE_WINDOW_SECONDS=30
KARAXYS_SCANNER_CAPACITY_RETRY_SECONDS=5
KARAXYS_SCANNER_ADMISSION_LEASE_SECONDS=1800
KARAXYS_NUCLEI_RATE_LIMIT_PER_SECOND=5
KARAXYS_NUCLEI_TEMPLATE_CONCURRENCY=1
KARAXYS_NUCLEI_HOST_CONCURRENCY=1
KARAXYS_NUCLEI_PAYLOAD_CONCURRENCY=2
KARAXYS_NUCLEI_PROBE_CONCURRENCY=5
